@using Microsoft.AspNetCore.Components.Authorization
@using Shared.Models

<div class="bg-dark text-white p-3 min-vh-100" style="width: 250px; direction: rtl; text-align: right;">
    <div class="mb-4 text-center border-bottom pb-2">
        <h6 class="text-muted small">منوی دسترسی</h6>
    </div>

    <ul class="nav nav-pills flex-column mb-auto gap-2">
        <li class="nav-item">
            <a href="products" class="nav-link text-white small d-flex align-items-center gap-2">
                📦 کاتالوگ محصولات
            </a>
        </li>

        <AuthorizeView Roles="@Roles.Customer">
            <Authorized>
                <li class="nav-item border-top pt-2 mt-2">
                    <span class="text-info small px-2 d-block mb-1">پنل کاربری</span>
                </li>
                <li class="nav-item">
                    <a href="my-orders" class="nav-link text-white small d-flex align-items-center gap-2">
                        🛒 تاریخچه سفارشات من
                    </a>
                </li>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="@Roles.Admin">
            <Authorized>
                <li class="nav-item border-top pt-2 mt-2">
                    <span class="text-warning small px-2 d-block mb-1">پنل مدیریت</span>
                </li>
                <li class="nav-item">
                    <a href="admin/products" class="nav-link text-white small d-flex align-items-center gap-2">
                        ⚙️ مدیریت انبار کالا
                    </a>
                </li>
                <li class="nav-item">
                    <a href="admin/products/create" class="nav-link text-white small d-flex align-items-center gap-2">
                        ➕ افزودن محصول جدید
                    </a>
                </li>
                <li class="nav-item">
                    <a href="admin/orders" class="nav-link text-white small d-flex align-items-center gap-2">
                        📋 مدیریت سفارشات کل
                    </a>
                </li>
            </Authorized>
        </AuthorizeView>
    </ul>
</div>
<style>
    .nav-pills .nav-link:hover:not(.active) {
        background-color: rgba(255, 255, 255, 0.05);
        color: #fff !important;
    }
</style>