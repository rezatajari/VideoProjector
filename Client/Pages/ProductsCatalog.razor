@page "/products"
@using Client.Components
@using Client.Services
@using Shared.Models
@inject ProductService ProductService

<h3 class="mb-4 text-dark border-bottom pb-2">🛍️ کاتالوگ و ویترین محصولات</h3>

@if (_products == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">در حال دریافت اطلاعات...</span>
        </div>
    </div>
}
else if (!_products.Any())
{
    <div class="alert alert-warning text-center" role="alert">
        هیچ محصولی در حال حاضر در ویترین مغازه موجود نیست.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var product in _products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary mb-2 align-self-start">@product.Category</span>
                        <h5 class="card-title fw-bold text-primary">@product.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@product.Description</p>

                        <hr class="text-muted" />

                        <div class="mb-3">
                            @if (product.RentalPricePerDay.HasValue)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small text-secondary">هزینه اجاره روزانه:</span>
                                    <span class="fw-bold text-success">@product.RentalPricePerDay.Value.ToString("N0") تومان</span>
                                </div>
                            }
                            @if (product.SalePrice.HasValue)
                            {
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-secondary">قیمت خرید قطعی:</span>
                                    <span class="fw-bold text-danger">@product.SalePrice.Value.ToString("N0") تومان</span>
                                </div>
                            }
                        </div>

                        <div class="d-grid gap-2 mt-auto">
                            @if (product.RentalPricePerDay.HasValue && product.QuantityForRental > 0)
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => RentProduct(product.Id)">
                                    📅 درخواست رزرو و اجاره
                                </button>
                            }
                            @if (product.SalePrice.HasValue && product.QuantityForSale > 0)
                            {
                                <button class="btn btn-danger btn-sm" @onclick="() => BuyProduct(product.Id)">
                                    🛒 خرید نقدی و قطعی
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
<OrderModal IsVisible="_isModalVisible" 
            SelectedProduct="_selectedProduct" 
            IsRental="_isRentalAction" 
            OnClose="CloseOrderModal" />

@code {
    private List<Product>? _products;
    private bool _isModalVisible = false;
    private Product? _selectedProduct;
    private bool _isRentalAction = false;

    protected override async Task OnInitializedAsync()
    {
        _products = await ProductService.GetProductsAsync();
    }

    private void RentProduct(int productId)
    {
        _selectedProduct = _products?.FirstOrDefault(p => p.Id == productId);
        _isRentalAction = true;
        _isModalVisible = true;
    }

    private void BuyProduct(int productId)
    {
        _selectedProduct = _products?.FirstOrDefault(p => p.Id == productId);
        _isRentalAction = false;
        _isModalVisible = true;
    }

    private async Task CloseOrderModal()
    {
        _isModalVisible = false;
        // ریفرش کردن کاتالوگ برای به‌روزرسانی موجودی‌های جدید انبار بعد از خرید/اجاره
        _products = await ProductService.GetProductsAsync();
    }
}