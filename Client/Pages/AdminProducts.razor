@page "/admin/products"
@using Client.Services
@using Microsoft.AspNetCore.Authorization
@using Shared.Models
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <h3 class="text-dark m-0">⚙️ مدیریت انبار و کالاها (پنل ادمین)</h3>
    <button class="btn btn-primary btn-sm d-flex align-items-center gap-2" @onclick="NavigateToCreate">
        <span>➕</span> افزودن محصول جدید
    </button>
</div>

@if (_products == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">در حال دریافت اطلاعات انبار...</span>
        </div>
    </div>
}
else if (!_products.Any())
{
    <div class="alert alert-info text-center">
        هیچ محصولی در انبار ثبت نشده است. با استفاده از دکمه بالا اولین کالا را اضافه کنید.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle text-center small">
            <thead class="table-dark">
                <tr>
                    <th>شناسه</th>
                    <th>نام کالا</th>
                    <th>دسته‌بندی</th>
                    <th>موجودیت فروش</th>
                    <th>قیمت فروش</th>
                    <th>موجودیت اجاره</th>
                    <th>اجاره روزانه</th>
                    <th>عملیات مدیریت</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in _products)
                {
                    <tr>
                        <td class="fw-bold">@product.Id</td>
                        <td class="text-start">@product.Name</td>
                        <td><span class="badge bg-secondary">@product.Category</span></td>
                        <td>@product.QuantityForSale عدد</td>
                        <td class="text-danger fw-bold">@(product.SalePrice?.ToString("N0") ?? "-")</td>
                        <td>@product.QuantityForRental عدد</td>
                        <td class="text-success fw-bold">@(product.RentalPricePerDay?.ToString("N0") ?? "-")</td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
                                <button class="btn btn-outline-warning btn-sm py-1 px-2" @onclick="() => NavigateToEdit(product.Id)">
                                    ✏️ ویرایش
                                </button>
                                <button class="btn btn-outline-danger btn-sm py-1 px-2" @onclick="() => DeleteProduct(product.Id)">
                                    🗑️ حذف
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_isDeleteModalVisible)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); direction: rtl; text-align: right;">
            <div class="modal-dialog modal-dialog-centered modal-sm">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-danger text-white py-2">
                        <h6 class="modal-title fw-bold">⚠️ تایید عملیات حذف</h6>
                    </div>
                    <div class="modal-body py-3">
                        <p class="small text-dark mb-0">آیا از حذف این محصول از لیست انبار اطمینان دارید؟ این عمل قابل بازگشت نیست.</p>
                    </div>
                    <div class="modal-footer d-flex gap-2 justify-content-end py-2">
                        <button type="button" class="btn btn-secondary btn-xs" @onclick="CloseDeleteModal">انصراف</button>
                        <button type="button" class="btn btn-danger btn-xs px-3" @onclick="ConfirmDeleteProduct">حذف قطعی</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<Product>? _products;
    private bool _isDeleteModalVisible = false;
    private int _productIdToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _products = await ProductService.GetProductsAsync();
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("admin/products/create");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"admin/products/edit/{id}");
    }

    private async Task DeleteProduct(int id)
    {
        _productIdToDelete = id;
        _isDeleteModalVisible = true;
    }

    private void CloseDeleteModal()
    {
        _isDeleteModalVisible = false;
    }

    private async Task ConfirmDeleteProduct()
    {
        _isDeleteModalVisible = false; 

        var success = await ProductService.DeleteProductAsync(_productIdToDelete);
        if (success)
        {
            await LoadProducts();
        }
    }
}