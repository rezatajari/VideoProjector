```gitignore
# =========================
# .NET / ASP.NET Core
# =========================

bin/
obj/
out/
publish/

# Build folders
[Dd]ebug/
[Rr]elease/

# =========================
# Visual Studio / Rider
# =========================

.vs/
.idea/

*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# =========================
# JetBrains Rider
# =========================

_ReSharper*/
*.DotSettings.user

# =========================
# VS Code
# =========================

.vscode/

# Optional:
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# =========================
# Logs
# =========================

*.log
logs/

# =========================
# NuGet
# =========================

*.nupkg
*.snupkg

# NuGet packages folder
packages/

# Generated NuGet files
project.assets.json
project.nuget.cache

# =========================
# Environment / Secrets
# =========================

.env
.env.*
secrets.json

# User secrets
**/secrets.json

# =========================
# EF Core
# =========================

*.db
*.db-shm
*.db-wal

# SQLite local databases
*.sqlite
*.sqlite3

# =========================
# Node / Frontend
# =========================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build outputs
dist/
build/

# =========================
# Docker
# =========================

docker-compose.override.yml

# =========================
# Testing / Coverage
# =========================

TestResults/
coverage/
coverage*.json
coverage*.xml

# =========================
# OS Files
# =========================

.DS_Store
Thumbs.db

# =========================
# Temporary Files
# =========================

tmp/
temp/
*.tmp

# =========================
# Generated Files
# =========================

Generated/
Generated Files/

# =========================
# BenchmarkDotNet
# =========================

BenchmarkDotNet.Artifacts/

# =========================
# Local History
# =========================

.localhistory/

# =========================
# Azure / Publish
# =========================

PublishScripts/
*.publishsettings
*.pubxml

# =========================
# Blazor WASM
# =========================

wwwroot/_framework/

# =========================
# Misc
# =========================

mono_crash.*
```
